classDiagram
    %% PawPal+ — pet care app UML class diagram

    class Owner {
        +str name
        +list pets
        +add_pet() void
        +remove_pet() void
        +list_pets() list
    }

    class Pet {
        +str name
        +str species
        +list tasks
        +add_task() void
        +show_tasks() list
    }

    class Task {
        +str description
        +str time_of_day
        +str priority
        +bool completed
        +mark_complete() void
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks() list
        +sort_tasks_by_time() list
        +get_incomplete_tasks() list
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : uses
